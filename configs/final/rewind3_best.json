{
  "name": "rewind3_best_local",
  "description": "Best observed rule-compliant rewind3 family run.",
  "model": "NlpHUST/gpt2-vietnamese",
  "prompt_template": "Câu hỏi: {q}\\nGiải:\\n",
  "training": {
    "epochs": 8,
    "lr": 0.008,
    "warmup_ratio": 0.15,
    "max_length": 256,
    "max_response_tokens": 256,
    "per_device_batch_size": 8,
    "grad_accum": 4,
    "weight_decay": 0.01,
    "computation_weight": 2.5,
    "anchor_weight": 6.0,
    "seed": 42
  },
  "decoding": {
    "style": "self_consistency",
    "num_samples": 15,
    "temperature": 0.4,
    "top_k": 40,
    "top_p": 0.9,
    "max_new_tokens": 80
  },
  "validation": {
    "n": 500,
    "raw_score": 1682,
    "max_raw_score": 5000,
    "score_pct": 0.3364,
    "exact_count": 157
  }
}
